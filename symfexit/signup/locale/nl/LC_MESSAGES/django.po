#: symfexit/signup/templates/signup/admin/change_form.html:7
msgid "Resend accepted email"
msgstr "Stuur acceptatie email nog een keer"

#: symfexit/signup/templates/signup/cancelled.html:18
#: symfexit/signup/templates/signup/open.html:18
#: symfexit/signup/templates/signup/payment.html:18
#: symfexit/signup/templates/signup/return.html:18
#: symfexit/signup/templates/signup/signup.html:15
#, python-format
msgid "Sign up for %(site_title)s"
msgstr "Inschrijven bij %(site_title)s"

#: symfexit/signup/templates/signup/cancelled.html:21
msgid ""
"\n"
"        You have cancelled your payment. To finish your registration you "
"must\n"
"        complete the contribution payment.\n"
"        "
msgstr ""
"\n"
"        Je hebt jouw betaling geannuleerd. Om jouw registratie te voltooien "
"moet\n"
"        je een contributiebetaling doen.\n"
"        "

#: symfexit/signup/templates/signup/cancelled.html:29
#: symfexit/signup/templates/signup/open.html:34
msgid ""
"\n"
"          Click <input type=\"submit\" class=\"text-primary inline cursor-"
"pointer\" value=\"here\" /> to return to the payment page\n"
"          "
msgstr ""
"\n"
"          Klik <input type=\"submit\" class=\"text-primary inline cursor-"
"pointer\" value=\"hier\" /> om terug te gaan naar de betalingspagina\n"
"          "

#: symfexit/signup/templates/signup/open.html:21
msgid ""
"\n"
"        Your payment is being processed. As soon as this is completed you\n"
"        will receive a confirmation e-mail.\n"
"        "
msgstr ""
"\n"
"        Jouw betaling wordt verwerkt. Zodra deze voltooid is\n"
"        krijg je een bevestigingsmail.\n"
"        "

#: symfexit/signup/templates/signup/open.html:27
msgid ""
"\n"
"        If you did not complete your payment then you can try again below.\n"
"        "
msgstr ""
"\n"
"        Als je jouw betaling niet af hebt gemaakt dan kun je het hieronder "
"nog een keer proberen.\n"
"        "

#: symfexit/signup/templates/signup/payment.html:21
#, python-format
msgid ""
"\n"
"        Hi %(first_name)s, thanks for registering! Complete your\n"
"        membership by making the first payment of €%(amount_euros)s.\n"
"        "
msgstr ""
"\n"
"        Hoi %(first_name)s, dank je wel voor jouw aanmelding! Maakt jouw\n"
"        lidmaatschapsaanmedling af door een contributiebetaling te doen van €"
"%(amount_euros)s.\n"
"        "

#: symfexit/signup/templates/signup/payment.html:27
msgid ""
"\n"
"        After your first payment consecutive payments will de deducted "
"automatically.\n"
"        "
msgstr ""
"\n"
"        Na je eerste betaling worden alle vervolgbetalingen automatisch "
"afgeschreven.\n"
"        "

#: symfexit/signup/templates/signup/return.html:21
msgid "Thanks for your payment!"
msgstr "Bedankt voor je betaling!"

#: symfexit/signup/templates/signup/return.html:24
msgid ""
"Your signup is now completed. You will receive a confirmation email on your "
"provided email address when your signup has been approved."
msgstr ""
"Je inschrijving is nu voltooid. Je ontvangt een bevestigingsmail op het "
"opgegeven e-mailadres wanneer je inschrijving is goedgekeurd."

#: symfexit/signup/templates/signup/signup.html:20
msgid "Register"
msgstr "Aanmelden"

#: symfexit/signup/templates/signup/signup.html:23
msgid "Registration is currently not possible."
msgstr "Aanmelden is nu niet mogelijk."

#: symfexit/signup/templates/signup/signup.html:25
msgid ""
"For admins: no active membership types are configured. Create a new one via "
"admin then Membership &gt; Membership types."
msgstr ""
"Voor admins: er is geen actief lidmaatschapstype geconfigureerd. Creëer een "
"nieuwe via admin dan Lidmaatschap &gt; Lidmaatschapstypes."
